---
import ButtonContact from "../components/ButtonContact.astro";

//social icos

import IcoLinkedIn from "../icons/SocialIcons/IcoLinkedIn.astro";
import IcoGithub from "../icons/SocialIcons/IcoGithub.astro";
import IcoTelegram from "../icons/SocialIcons/IcoTelegram.astro";
import IcoInstagram from "../icons/SocialIcons/IcoInstagram.astro";

//misc icos

import IcoArrowDown from "../icons/IconsMisc/IcoArrowDown.astro";
const classHomeSocial =
  "transform transition-transform duration-300 group-hover:-translate-x-5";
---

<section
  id="Home"
  class="h-screen w-5/6 m-auto flex align items-center justify-between relative"
>
  <div class="w-1/2 h-full flex justify-center place-content-center]">
    <div class="w-3/4 flex flex-col m-auto">
      <article>
        <h1 class="text-7xl font-bold">
          I'm<span class="text-third-color"> Martin Viera</span>
        </h1>
        <div class="w-96">
          <h3
            class="animate-typing overflow-hidden whitespace-nowrap border-r-4 border-r-white pr-5 text-4xl text-first-font font-semibold italic w-80[22rem]"
          >
            a frontend developer.
          </h3>
        </div>
      </article>
      <ButtonContact />
    </div>
  </div>
  <div class="w-1/2 h-full flex justify-between">
    <div class="w-4/5 h-screen flex items-center justify-center ">
      <img
        src="photo2.webp"
        alt="Profile photo"
        class="border-solid border-4 border-third-color h-2/4 w-auto"
      />
    </div>

    <div class="flex flex-col h-screen justify-end mr-0 mb-10">
      <span class="bg-third-color w-2 h-64 mx-auto shadow-custom-shadow"></span>
      <ul class="flex flex-col gap-2 mt-5 mb-10">
        <li>
          <a
            href="https://www.linkedin.com/in/martin-rodrigo-viera-royer-98a45328a/"
            target="_blank"
            rel="noopener noreferrer"
            class="group"
          >
            <IcoLinkedIn
              class={classHomeSocial + " hover:stroke-third-color"}
            />
          </a>
        </li>
        <li>
          <a
            href="https://github.com/Vieramaster"
            target="_blank"
            rel="noopener noreferrer"
            class="group"
          >
            <IcoGithub class={classHomeSocial + " hover:fill-third-color"} />
          </a>
        </li>

        <li>
          <a
            href="https://www.instagram.com/martin_viera90/ "
            target="_blank"
            rel="noopener noreferrer"
            class="group"
          >
            <IcoInstagram
              class={classHomeSocial + " hover:fill-third-color"}
              aria-hidden="true"
            />
          </a>
        </li>
        <li>
          <a
            href="https://www.instagram.com/martin_viera90/ "
            target="_blank"
            rel="noopener noreferrer"
            class="group"
          >
            <IcoTelegram
              class={classHomeSocial + " hover:stroke-third-color"}
            />
          </a>
        </li>
      </ul>
    </div>
  </div>

  <a href="#Skills/About" class="absolute bottom-0 left-1/2" aria-label="scroll"
    ><IcoArrowDown /></a
  >
</section>
