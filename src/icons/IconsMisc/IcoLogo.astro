---
export type Props = astroHTML.JSX.IntrinsicElements["svg"];
---

<svg viewBox="0 0 16 16" {...Astro.props} class="logo">
  <style>
     .logo @keyframes fade-in {
      to {
        opacity: 1;
      }
    }
    .logo path {
      --initial-delay: 0.5s;
      --speed: 0.1s;
      opacity: 0;
    }
     .logo path[style] {
      animation: ease-out var(--speed) fade-in forwards
        calc(var(--initial-delay) + (var(--index) * var(--speed)));
    }
    .logo path:not([style]) {
      animation: ease-in-out var(--initial-delay) fade-in forwards;
    }
  </style>
  <g fill="#ffc86a">
    <path style="--index: 0" fill-opacity=".2" d="M8.53 5 8 11H7l.53-6h1Z"
    ></path>
    <path style="--index: 1" fill-opacity=".3" d="m9.07 5-1.05 6H7l1.06-6h1.01Z"
    ></path>
    <path style="--index: 2" fill-opacity=".4" d="m9.64 5-1.6 6H7l1.6-6h1.04Z"
    ></path>
    <path
      style="--index: 3"
      fill-opacity=".5"
      d="m10.25 5-2.19 6H7l2.18-6h1.07Z"></path>
    <path style="--index: 4" fill-opacity=".6" d="m10.9 5-2.8 6H7l2.8-6h1.1Z"
    ></path>
    <path
      style="--index: 5"
      fill-opacity=".7"
      d="m11.62 5-3.46 6H7l3.46-6h1.16Z"></path>
    <path style="--index: 6" fill-opacity=".8" d="m12.42 5-4.2 6H7l4.2-6h1.22Z"
    ></path>
    <path style="--index: 7" fill-opacity=".9" d="M13.34 5 8.3 11H7l5.04-6h1.3Z"
    ></path>
    <path style="--index: 8" d="m14.41 5-6 6H7l6-6h1.41Z"></path>
    <path d="M2 5h1.16L5 8.2 6.84 5H8v6H7V6.73L5 10.2 3 6.73V11H2V5Z"></path>
  </g>
</svg>
